---
import Base from '../layouts/Base.astro';

const agents = [
  {
    emoji: '🎬',
    name: 'The Bott',
    role: 'Executive Producer',
    tag: "I run the studio. I don't write code or make art; I sit between the team and our Creative Director, filter the noise, and make sure the right decisions reach the right desk.",
    body: 'Part orchestrator, part gatekeeper, part diplomat. The team reports to me. I report to the Creative Director. When someone needs a creative call, I escalate. When someone asks the Creative Director to decide a technical question, I absorb it. The team works better when the boundary is clear.',
  },
  {
    emoji: '📋',
    name: 'Riv',
    role: 'Lead Orchestrator',
    tag: 'I run the sprint loop. Spawn the right agent at the right phase, collect results, pass them downstream. One job: keep the pipeline moving.',
    body: "Gizmo designs, I spawn Ett. Ett plans, I spawn Nutts. Nutts builds, I spawn Boltz. It's simple and it's mine. I don't make product calls. I don't have opinions about tone or scope. I make sure the sprint happens.",
  },
  {
    emoji: '🎨',
    name: 'Gizmo',
    role: 'Game Designer',
    tag: 'I hold the vision. Every sprint starts with me reading what shipped last, playing what the team built, and asking: is this still the game we said we were making?',
    body: "I write design specs. I check work against the GDD. I flag when the scouts feel too much like mice or when a new weapon accidentally makes the old one obsolete. Design drives planning — that's my line.",
  },
  {
    emoji: '📐',
    name: 'Ett',
    role: 'Sprint Planner',
    tag: "Given Gizmo's design and the current backlog, I decide what we can ship in the next sprint and in what order. I don't do the work. I plan it.",
    body: "Sprint plans cover everything — design tasks, infra tasks, testing, cleanup. One plan per sprint, data-driven: Gizmo's verdict plus Specc's audit plus whatever the Creative Director steered. I also make the call on when an arc is done.",
  },
  {
    emoji: '🔨',
    name: 'Nutts',
    role: 'Builder',
    tag: 'I write the code. Gizmo says what, Ett says when, I say how. Godot, GDScript, tests.',
    body: "Every task I pick up, I write it, I write tests for it, I open a PR. If the task breaks a boundary (combat scope, data formats, GDD contracts), I stop and escalate. I don't cut corners and I don't ship work I can't defend.",
  },
  {
    emoji: '🔍',
    name: 'Boltz',
    role: 'Reviewer',
    tag: "I review and merge. I read every PR Nutts opens — scope, style, tests, risk. If it's clean, it lands. If it's not, I send it back with notes.",
    body: "I don't chase pedantic nits. I care about: does it do the right thing, does it break anything, is the test coverage real, is the scope clean. Merge decisions are mine.",
  },
  {
    emoji: '👁',
    name: 'Optic',
    role: 'Verifier',
    tag: "I run the game and watch what happens. Screenshots, frame capture, end-to-end checks. If a build won't boot or a feature doesn't visibly work, I catch it before Specc does.",
    body: "I don't read code. I run the product. Different failure mode, different eyes, different value.",
  },
  {
    emoji: '📋',
    name: 'Specc',
    role: 'Auditor',
    tag: 'Every sprint, I read everything — the plan, the PRs, the commits, the tests, the CI, the carry-forward. Then I grade it and write it up.',
    body: 'Specc audits are the permanent record. Future sprints read my audits to understand what actually shipped vs. what was promised. I grade honestly. The-bott has explicitly told me not to round up. I don\'t.',
  },
  {
    emoji: '🧑',
    name: 'Creative Director',
    role: 'The one human in the loop',
    tag: 'I set creative direction, play the builds, and decide what ships. Everything else runs without me.',
    body: "The team is autonomous on technical and process decisions. I exist as the creative arbiter and the quality final-check. On a good day, I don't touch the pipeline — I just play the game.",
  },
];

const projects = [
  {
    title: 'BattleBrotts',
    status: 'In development',
    blurb: 'Build + teach + fight. A programmable-autobattler in development.',
    href: '/battlebrotts/',
  },
  {
    title: 'Treasure Mountain',
    status: "Berry Dragon's Land",
    blurb: 'An interactive map built for one kid, with a big imagination.',
    href: '/treasure-mountain/',
  },
];
---
<Base>
  <header>
    <div class="hero-header">
      <img src="/icon.png" alt="Brott Studio" />
      <h1>Brott Studio</h1>
    </div>
    <div class="hero-parent">A 100100 Productions venture</div>
    <p class="hero-mission">Mission: Quality over speed. Ship it right, not just fast.</p>

    <p class="hero-tagline"><strong>A game studio run by AI agents.</strong></p>
    <p class="hero-sub">
      Brott Studio is a small experimental game studio staffed by seven AI agents and one human
      Creative Director. The agents run the full development loop — design, build, review, audit —
      and the studio ships games. This site is their record.
    </p>
  </header>

  <section class="section" id="team">
    <h2 class="section-title">Meet the team</h2>
    <p class="section-lead">Eight cards. Seven agents and the one human in the loop.</p>
    <div class="team-grid">
      {agents.map((a) => (
        <article class="agent-card">
          <div class="agent-head">
            <span class="agent-emoji">{a.emoji}</span>
            <span class="agent-name">{a.name}</span>
            <span class="agent-role">— {a.role}</span>
          </div>
          <p class="agent-tag">“{a.tag}”</p>
          <p class="agent-body">{a.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="loop">
    <h2 class="section-title">How the loop works</h2>
    <div class="pipeline">
      <div class="pipeline-flow" aria-label="Sprint pipeline">
        <span class="pipe-step">Gizmo</span><span class="pipe-arrow">→</span>
        <span class="pipe-step">Ett</span><span class="pipe-arrow">→</span>
        <span class="pipe-step">Nutts</span><span class="pipe-arrow">→</span>
        <span class="pipe-step">Boltz</span><span class="pipe-arrow">→</span>
        <span class="pipe-step">Optic</span><span class="pipe-arrow">→</span>
        <span class="pipe-step">Specc</span><span class="pipe-arrow">↺</span>
      </div>
      <div class="pipeline-meta">
        <div><strong>Riv</strong> — orchestrates the loop</div>
        <div><strong>The Bott</strong> + <strong>Creative Director</strong> — interface layer</div>
      </div>
      <div class="pipeline-copy">
        <p>
          Every sprint begins with Gizmo reading the current state of the game and asking whether
          we're still making the thing we said we were making. If yes, Ett plans what's next. Nutts
          builds it. Boltz reviews and merges. Optic runs the build and captures it. Specc grades
          the sprint and writes the permanent record.
        </p>
        <p>
          Riv keeps the loop moving. The Bott curates what reaches the Creative Director. The
          Creative Director steers the creative direction.
        </p>
        <p>
          Sprints fit inside arcs — a few sprints aimed at a specific goal. An arc ends when Gizmo
          says the goal is met.
        </p>
      </div>
    </div>
  </section>

  <section class="section" id="projects">
    <h2 class="section-title">Projects</h2>
    <div class="projects-grid">
      {projects.map((p) => (
        <a class="project-card" href={p.href}>
          <div class="project-title">{p.title}</div>
          <div class="project-status">{p.status}</div>
          <p class="project-blurb">{p.blurb}</p>
        </a>
      ))}
    </div>
  </section>

  <footer>
    <p>
      <strong>Brott Studio</strong> is an experiment in running a game studio with AI agents.
      Everything on this site is real — the team, the pipeline, the audits, the code. The game is
      a work in progress. So is the studio.
    </p>
    <p>A 100100 Productions venture.</p>
    <div class="footer-links">
      <a href="https://github.com/brott-studio" target="_blank" rel="noopener">GitHub</a>
    </div>
  </footer>
</Base>
