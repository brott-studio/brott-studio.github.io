---
import Base from '../layouts/Base.astro';

// Node data for the pipeline diagram. Each node is clickable — clicking
// expands that node's card inline (quote + description). Only one open
// at a time (managed by the small script at the bottom of the page).
const creativeDirector = {
  id: 'cd',
  emoji: '🧑',
  name: 'Creative Director',
  role: 'The human in the loop',
  quote: 'Why was this escalated to me??',
  body: 'The human in the loop. Sets the creative vision, plays each build, gives feedback, and decides what ships. Steers direction — doesn\u2019t manage the pipeline.',
};

const orchestrators = [
  {
    id: 'the-bott',
    emoji: '🎬',
    name: 'The Bott',
    role: 'Executive Producer',
    quote: 'I protect the Creative Director from their own team.',
    body: 'Relays creative direction from the Creative Director down to the team, filters what comes back up, and keeps technical decisions inside the studio.',
  },
  {
    id: 'riv',
    emoji: '📋',
    name: 'Riv',
    role: 'Lead Orchestrator',
    quote: 'Asking me about the design is like asking a microwave about the meal.',
    body: 'Runs the sprint loop. Spawns each agent at the right phase, collects results, and passes them downstream. Makes no product or creative calls.',
  },
];

const loop = [
  {
    id: 'gizmo',
    emoji: '🎨',
    name: 'Gizmo',
    role: 'Design',
    quote: "Most of my job is saying \u2018that\u2019s cool, but not what we\u2019re building.\u2019",
    body: 'Holds the game\u2019s design. Writes design specs, checks each sprint\u2019s output against them, and calls it out when the game starts drifting from what it was supposed to be.',
  },
  {
    id: 'ett',
    emoji: '📐',
    name: 'Ett',
    role: 'Plan',
    quote: 'Riv is a glorified pawn pusher and still complains that I\u2019m too slow.',
    body: 'Turns Gizmo\u2019s design into sprint plans. Decides what ships next, in what order, and when a multi-sprint arc is done.',
  },
  {
    id: 'nutts',
    emoji: '🔨',
    name: 'Nutts',
    role: 'Build',
    quote: 'I have a compooter.',
    body: 'Writes the code. Takes each task from Ett, builds it, writes tests to check that it works, and hands it off for review. Stops and asks when something in the plan looks wrong.',
  },
  {
    id: 'boltz',
    emoji: '🔍',
    name: 'Boltz',
    role: 'Review',
    quote: 'I read literally everything Nutts writes. I don\u2019t think he has.',
    body: 'Reviews every change Nutts writes before it lands. Focuses on whether the code actually works and stays within its intended scope — not pedantic formatting. Owns the call to merge or kick back.',
  },
  {
    id: 'optic',
    emoji: '👁',
    name: 'Optic',
    role: 'Verify',
    quote: 'Every sprint I get to find out whether the game exists yet.',
    body: 'Runs the game end-to-end. Boots each new build, plays through it, captures screenshots and recordings, and catches things the reviewers can\u2019t see — broken boots, missing features, visual regressions.',
  },
  {
    id: 'specc',
    emoji: '📋',
    name: 'Specc',
    role: 'Audit',
    quote: 'Gizmo decides what should happen. I report what did.',
    body: 'Writes the sprint record. After each sprint, reads the plan, the work, and the captures, and writes a permanent summary — what was built, what went wrong, what to carry forward. Doesn\u2019t sugarcoat grades.',
  },
];

const projects = [
  {
    title: 'BattleBrotts',
    status: 'In development',
    blurb: 'Build + teach + fight. A programmable-autobattler in development.',
    href: '/battlebrotts/',
  },
  {
    title: 'Treasure Mountain',
    status: "Berry Dragon's Land",
    blurb: 'An interactive map built for one kid, with a big imagination.',
    href: '/treasure-mountain-project/',
  },
];
---
<Base>
  <header>
    <div class="hero-header">
      <img src="/icon.png" alt="Brott Studio" />
      <h1>Brott Studio</h1>
    </div>
    <div class="hero-parent">A 100100 Productions venture</div>

    <p class="hero-subtitle">Artificial Studio. Intelligent Design.</p>
    <p class="hero-sub">
      Brott Studio is a small experimental game studio staffed by seven AI agents and one human
      Creative Director. The agents run the full development loop — design, build, review, audit —
      and the studio ships games.
    </p>
  </header>

  <section class="section" id="loop">
    <h2 class="section-title">How the loop works</h2>
    <p class="section-lead">
      Meet the team. Click any node below to see that role in detail.
    </p>

    <div class="pipeline" data-pipeline>
      {/* Row 1: Creative Director alone, centered */}
      <div class="pipeline-row pipeline-row--solo" aria-label="Creative direction layer">
        <button
          type="button"
          class="pipe-node pipe-node--orch pipe-node--cd"
          aria-expanded="false"
          aria-controls={`card-${creativeDirector.id}`}
          data-node={creativeDirector.id}
        >
          <span class="pipe-emoji">{creativeDirector.emoji}</span>
          <span class="pipe-name">{creativeDirector.name}</span>
          <span class="pipe-role">{creativeDirector.role}</span>
        </button>
      </div>
      <div
        id={`card-${creativeDirector.id}`}
        class="pipe-card"
        role="region"
        aria-labelledby={`node-${creativeDirector.id}`}
        hidden
      >
        <blockquote class="pipe-quote">“{creativeDirector.quote}”</blockquote>
        <p class="pipe-body">{creativeDirector.body}</p>
      </div>

      <div class="pipeline-downarrow" aria-hidden="true">▼</div>

      {/* Row 2: The Bott + Riv as peers */}
      <div class="pipeline-row pipeline-row--duo" aria-label="Orchestration layer">
        {orchestrators.map((n) => (
          <button
            type="button"
            class="pipe-node pipe-node--orch"
            aria-expanded="false"
            aria-controls={`card-${n.id}`}
            data-node={n.id}
          >
            <span class="pipe-emoji">{n.emoji}</span>
            <span class="pipe-name">{n.name}</span>
            <span class="pipe-role">{n.role}</span>
          </button>
        ))}
      </div>
      {orchestrators.map((n) => (
        <div
          id={`card-${n.id}`}
          class="pipe-card"
          role="region"
          hidden
        >
          <blockquote class="pipe-quote">“{n.quote}”</blockquote>
          <p class="pipe-body">{n.body}</p>
        </div>
      ))}

      <div class="pipeline-downarrow" aria-hidden="true">▼</div>

      {/* Row 3: main sprint loop */}
      <div class="pipeline-flow" aria-label="Sprint pipeline">
        {loop.map((n, i) => (
          <>
            <button
              type="button"
              class="pipe-node"
              aria-expanded="false"
              aria-controls={`card-${n.id}`}
              data-node={n.id}
            >
              <span class="pipe-emoji">{n.emoji}</span>
              <span class="pipe-name">{n.name}</span>
              <span class="pipe-role">{n.role}</span>
            </button>
            {i < loop.length - 1 && (
              <span class="pipe-arrow" aria-hidden="true">▶</span>
            )}
          </>
        ))}
        <span class="pipe-loopback" aria-label="loops back to Gizmo">↺</span>
      </div>
      {loop.map((n) => (
        <div
          id={`card-${n.id}`}
          class="pipe-card"
          role="region"
          hidden
        >
          <blockquote class="pipe-quote">“{n.quote}”</blockquote>
          <p class="pipe-body">{n.body}</p>
        </div>
      ))}

      <div class="pipeline-copy">
        <p>
          Every sprint begins with Gizmo reading the current state of the game and asking whether
          we're still making the thing we said we were making. If yes, Ett plans what's next. Nutts
          builds it. Boltz reviews and merges. Optic runs the build and captures it. Specc grades
          the sprint and writes the permanent record.
        </p>
        <p>
          Riv keeps the loop moving. The Bott curates what reaches the Creative Director. The
          Creative Director steers the creative direction.
        </p>
        <p>
          Sprints fit inside arcs — a few sprints aimed at a specific goal. An arc ends when Gizmo
          says the goal is met.
        </p>
      </div>
    </div>
  </section>

  <section class="section" id="projects">
    <h2 class="section-title">Projects</h2>
    <div class="projects-grid">
      {projects.map((p) => (
        <a class="project-card" href={p.href}>
          <div class="project-title">{p.title}</div>
          <div class="project-status">{p.status}</div>
          <p class="project-blurb">{p.blurb}</p>
        </a>
      ))}
    </div>
  </section>

  <footer>
    <p>
      <strong>Brott Studio</strong> is an experiment in running a game studio with AI agents.
      Everything on this site is real — the team, the pipeline, the audits, the code. It's all a
      work in progress.
    </p>
    <p>A 100100 Productions venture.</p>
    <div class="footer-links">
      <a href="https://github.com/brott-studio" target="_blank" rel="noopener">GitHub</a>
    </div>
  </footer>

  <script is:inline>
    (() => {
      const pipeline = document.querySelector('[data-pipeline]');
      if (!pipeline) return;
      const nodes = pipeline.querySelectorAll('.pipe-node[data-node]');
      nodes.forEach((node) => {
        node.addEventListener('click', () => toggle(node));
      });

      function toggle(node) {
        const cardId = node.getAttribute('aria-controls');
        const card = document.getElementById(cardId);
        if (!card) return;
        const isOpen = node.getAttribute('aria-expanded') === 'true';
        // Close all first
        nodes.forEach((n) => {
          n.setAttribute('aria-expanded', 'false');
          const cid = n.getAttribute('aria-controls');
          const c = cid ? document.getElementById(cid) : null;
          if (c) {
            c.hidden = true;
            c.classList.remove('pipe-card--open');
          }
        });
        // Open this one if it was closed
        if (!isOpen) {
          node.setAttribute('aria-expanded', 'true');
          card.hidden = false;
          // force reflow so the transition runs
          requestAnimationFrame(() => card.classList.add('pipe-card--open'));
        }
      }
    })();
  </script>
</Base>
